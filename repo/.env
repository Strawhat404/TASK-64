# ============================================================
# Local Operations & Compliance Console - Environment Variables
# ============================================================
# Copy this file to .env and adjust values for your environment.
# Do NOT commit your .env file to version control.
# ============================================================

# --- PostgreSQL Database ---
POSTGRES_USER=compliance
POSTGRES_PASSWORD=compliance_secret
POSTGRES_DB=compliance_console

# --- Backend (Go) ---
DB_HOST=db
DB_PORT=5432
DB_USER=compliance
DB_PASSWORD=compliance_secret
DB_NAME=compliance_console

# --- Encryption ---
# 32-byte hex-encoded AES-256 master key (required for production)
# Generate with: openssl rand -hex 32
# MASTER_KEY=

# --- TLS (Backend Direct) ---
# Backend auto-detects certs. Generate with: cd backend && bash certs/generate.sh
# TLS_CERT_FILE=certs/server.crt
# TLS_KEY_FILE=certs/server.key

