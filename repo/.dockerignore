# Secrets — must never be baked into images
.env

# Frontend dependencies (installed during Docker build)
frontend/node_modules/
frontend/dist/

# Go build cache
backend/bin/

# TLS certs (mounted at runtime via volume, not baked in)
backend/certs/*.crt
backend/certs/*.key
backend/certs/*.pem

# Git history — no reason to include in build context
.git/
.gitignore

# OS noise
.DS_Store
**/*.swp
Thumbs.db
